#include <stdio.h>

int main() {
    int choice;
    double a, b, result;

    while (1) {
        printf("\nSimple Calculator\n");
        printf("1. Addition\n");
        printf("2. Subtraction\n");
        printf("3. Multiplication\n");
        printf("4. Division\n");
        printf("5. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        if (choice == 5)
            break;

        printf("Enter two numbers: ");
        scanf("%lf %lf", &a, &b);

        switch (choice) {
            case 1:
                result = a + b;
                printf("Result = %.2lf\n", result);
                break;
            case 2:
                result = a - b;
                printf("Result = %.2lf\n", result);
                break;
            case 3:
                result = a * b;
                printf("Result = %.2lf\n", result);
                break;
            case 4:
                if (b == 0)
                    printf("Division by zero not allowed\n");
                else {
                    result = a / b;
                    printf("Result = %.2lf\n", result);
                }
                break;
            default:
                printf("Invalid choice\n");
        }
    }

    return 0;
}

