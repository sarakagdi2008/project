    while (true) {
        cout << "\n1.Add Record\n2.View Records\n3.Exit\nEnter Choice: ";
        cin >> choice;

        if (choice == 1) {
            fout.open("student.dat", ios::binary | ios::app);
            s.input();
            fout.write((char*)&s, sizeof(s));
            fout.close();
        }
        else if (choice == 2) {
            fin.open("student.dat", ios::binary);
            while (fin.read((char*)&s, sizeof(s))) {
                s.display();
